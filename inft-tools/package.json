{
  "name": "@reckon-protocol/inft-tools",
  "version": "0.1.0",
  "description": "iNFT brain blob encryption, decryption, and 0G Storage upload for Reckon challenger agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "reckon-provision": "./dist/provision.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "provision": "node --import tsx src/provision.ts",
    "setup-env": "node --import tsx src/setup-env.ts",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@0gfoundation/0g-ts-sdk": "^1.2.6",
    "@noble/ed25519": "^2.2.3",
    "@noble/hashes": "^1.7.1",
    "@reckon-protocol/types": "*",
    "dotenv": "^16.4.0",
    "ethers": "^6.13.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
