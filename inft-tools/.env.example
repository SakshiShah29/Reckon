# Required
PRIVATE_KEY=0x...                  # Owner wallet private key (signs challenge string, pays mint fee)
CHALLENGER_NFT_ADDRESS=0x5508286dC8A3387ce6f3b93347995AA60C4001aE       # ChallengerNFT proxy address on 0G Galileo
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
AXL_PEM_PATH=./axl-identity.pem    # Ed25519 private key PEM (generate with: openssl genpkey -algorithm ed25519 -out axl-identity.pem)

# Optional
AGENT_ADDRESS=0x...                # Mint to a different address (defaults to owner)
KH_API_KEY=kh_...                  # KeeperHub API key (stored in brain blob for future use)
AGENT_CHALLENGE_STRING=reckon-agent-auth-v1  # Challenge string for brain blob encryption
MIN_SLASH_USDC=50000000            # Minimum slash amount in USDC atomic units (default: 50 USDC)
MAX_BOND_PCT=25                    # Max percentage of bond to risk per challenge (default: 25)
ZG_MODEL=qwen/qwen-2.5-7b-instruct                 # 0G Compute model (must match your provider)
