# RPC
BASE_RPC_URL=http://localhost:8545
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

# Agent identity
AGENT_TOKEN_ID=1
AGENT_CHALLENGE_STRING=reckon-agent-auth-v1
ZG_AGENT_PRIVATE_KEY=0x...

# 0G Compute — 3 provider sub-accounts for parallel inference (one per AXL node)
# Run `node --import tsx src/provision.ts` to set up sub-accounts
ZG_COMPUTE_PROVIDER_ADDRESS=0x...
ZG_COMPUTE_PROVIDER_1=0x...
ZG_COMPUTE_PROVIDER_2=0x...
ZG_COMPUTE_PROVIDER_3=0x...

# KeeperHub
KH_API_KEY=kh_...
KH_WEBHOOK_URL=https://app.keeperhub.com/api/v1/workflows/...

# Contract addresses (set after deployment)
FILL_REGISTRY_ADDRESS=0x...
CHALLENGER_ADDRESS=0x...
EBBO_ORACLE_ADDRESS=0x...

# MongoDB (read-only, for dashboard fallback reads)
MONGODB_URI_RO=mongodb+srv://consumer:PASSWORD@cluster.mongodb.net/reckon

# Owner signature for brain blob decryption
OWNER_SIGNATURE=0x...
