# RPC — agent runs strictly on Base Sepolia
BASE_RPC_URL=https://sepolia.base.org
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

# Agent identity
AGENT_TOKEN_ID=1
AGENT_CHALLENGE_STRING=reckon-agent-auth-v1
ZG_AGENT_PRIVATE_KEY=0x...

# 0G Compute (router API — get key at pc.0g.ai)
ZG_API_KEY=sk-...

# Contract addresses (set after deployment)
FILL_REGISTRY_ADDRESS=0x...
CHALLENGER_ADDRESS=0x...
CHALLENGER_REGISTRY_ADDRESS=0x...
SOLVER_BOND_VAULT_ADDRESS=0x...

# Bootstrap: ENS registration via relayer (optional — skip to register manually)
RELAYER_URL=http://localhost:10000
CHALLENGER_LABEL=my-challenger

# MongoDB (read-only, for dashboard fallback reads)
MONGODB_URI_RO=mongodb+srv://consumer:PASSWORD@cluster.mongodb.net/reckon

# Owner signature for brain blob decryption
OWNER_SIGNATURE=0x...
BRAIN_ROOT_HASH=0x..

# Gensyn Setup
AXL_API_URL=
AXL_PEER_KEYS=

# KeeperHub — challenge submission
KH_WEBHOOK_URL=https://app.keeperhub.com/api/workflows/krgoqq0af5urb1k8vnww7/webhook
KH_WEBHOOK_API_KEY=wfb_...
KH_API_KEY=kh_...

# KeeperHub — EBBO benchmark reads (optional — omit to read via direct RPC)
KH_EBBO_WEBHOOK_URL=https://app.keeperhub.com/api/workflows/mz0199aw1djkmld7gqxyw/webhook
