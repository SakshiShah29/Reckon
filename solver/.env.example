# Solver identity (must be registered in SolverRegistry + bonded in SolverBondVault)
SOLVER_PRIVATE_KEY=0x...

# Base network
BASE_RPC_URL=https://mainnet.base.org

# Contract addresses (from DeployBase output)
RECKON_VALIDATOR_ADDRESS=0x...

# Server
PORT=3000

# Bootstrap (auto-register + bond on startup)
SOLVER_BOND_VAULT_ADDRESS=0x...
RELAYER_URL=http://localhost:10000
SOLVER_LABEL=my-solver

# Swapper test script (swap-test.ts)
SWAPPER_PRIVATE_KEY=0x...
SOLVER_URL=http://localhost:3000
EBBO_ORACLE_ADDRESS=0x...
